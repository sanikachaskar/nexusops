{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./frontend/js/dist",
    "rootDir": "./frontend/js"
  },
  "include": ["frontend/js/**/*"],
  "exclude": ["node_modules"]
}
